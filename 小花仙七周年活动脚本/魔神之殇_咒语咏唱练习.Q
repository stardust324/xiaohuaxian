[Script]
Call Lib.ИНМў.ЪЭЗХИНМў("D:\аЁЛЈЯЩ\ЦпжмФъ\ФЇЩёжЎщф\жфгявїГЊСЗЯА")
'==========вдЯТЪЧАДМќОЋСщТМжЦЕФФкШн==========
MoveTo 974, 764
Delay 1000
LeftClick 1
Delay 1
LeftUp 1
'==========вдЩЯЪЧАДМќОЋСщТМжЦЕФФкШн==========

Dim flag,l,r
flag = True
Do
	Rem begin
	//ЦСФЛЧјгђЪЙгУЯрЫЦЖШВщевЭМЦЌ
	зјБъ = Split(Plugin.TURING.FindImage(1200, 263, 1343, 380, "D:\аЁЛЈЯЩ\ЦпжмФъ\ФЇЩёжЎщф\жфгявїГЊСЗЯА\again.bmp", 0.5), ",")
	x = CInt(зјБъ(0))
	y = CInt(зјБъ(1))
	TracePrint x
	TracePrint y
	If x > 0 And y > 0 Then 
		MoveTo 1085, 720
		Delay 500
		LeftClick 1
		Delay 1
		LeftUp 1
	End If
	If flag Then 
		TracePrint r
		If r >= 1250 Then 
			flag = False
		End If
		KeyDown "Right", 1
		Delay 200
		KeyUp "Right", 1
	Else 
		TracePrint l
		If l <= 90 Then 
			flag = True
		End If
		KeyDown "Left", 1
		Delay 200
		KeyUp "Left", 1
	End If
	Delay 400
	Call Plugin.TURING.Pixel_FromScreen(238,96, 1681,973)
	Call Plugin.TURING.Filter_Posterization(2)
	Call Plugin.TURING.Filter_Binaryzation("FFFF00")
	num = Plugin.TURING.Incise_ScopeAisle(50, 50, "100-1000", "100-1000")
	If num < 0 Then 
		TracePrint num + 1
		Goto begin
	End If
	//ЛёШЁЧаИюзжЗћЪ§ОнФкШн
	data = Split(Plugin.TURING.Incise_GetCharData(), "|")
	For i = 0 To num
    	//зжЗћдЄРР
    	//Call Plugin.TURING.Incise_Preview(i)
    	зжЗћ = Split(data(i), ",")
    	l = CInt(зжЗћ(0)) 
    	r = CInt(зжЗћ(0)) + CInt(зжЗћ(2))
	Next
Loop
