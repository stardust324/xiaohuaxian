[Script]
Call Lib.ИНМў.ЪЭЗХИНМў("D:\аЁЛЈЯЩ\ЦпжмФъ\ФЇЩёжЎщф\ЛЈОЋСщбЕСЗгЊ")
'==========вдЯТЪЧАДМќОЋСщТМжЦЕФФкШн==========
MoveTo 1041, 733
Delay 1000
LeftClick 1
Delay 1
LeftUp 1
'==========вдЩЯЪЧАДМќОЋСщТМжЦЕФФкШн==========
Do
	Rem begin
	Delay 500
	//ЦСФЛЧјгђЪЙгУЯрЫЦЖШВщевЭМЦЌ
	зјБъ = Split(Plugin.TURING.FindImage(1001,661 , 1209,753 , "D:\аЁЛЈЯЩ\ЦпжмФъ\ФЇЩёжЎщф\ЛЈОЋСщбЕСЗгЊ\again.bmp", 0.9),",")
	x = CInt(зјБъ(0))
	y = CInt(зјБъ(1))
	If x > 0 And y > 0 Then 
		MoveTo 1094, 709
		Delay 500
		LeftClick 1
		Delay 1
		LeftUp 1
	End If
	Call Plugin.TURING.Pixel_GetClpImageData()   
	Call Plugin.TURING.Incise_EraseData()
	//ЛёШЁЦСФЛЭМЯёЪ§Он
	Call Plugin.TURING.Pixel_FromScreen(234, 460, 1685, 670)
	Call Plugin.TURING.Filter_Binaryzation("999999")
	//Call Plugin.TURING.Pixel_Preview()
	num = Plugin.TURING.Incise_ScopeAisle(50, 50)
	If num < 0 Then 
		TracePrint num + 1
		Goto begin
	End If
	//ЛёШЁЧаИюзжЗћЪ§ОнФкШн
	data = Split(Plugin.TURING.Incise_GetCharData(), "|")
	For i = 0 To num
    	//зжЗћдЄРР
    	//Call Plugin.TURING.Incise_Preview(i)
    	зжЗћ = Split(data(i), ",")
    	x = CInt(зжЗћ(0)) + CInt(зжЗћ(2)) + 234 + 15
    	y = CInt(зжЗћ(1)) + 460 +230
    	MoveTo x, y
    	Delay 500
    	LeftClick 1
    	Delay 1
    	LeftUp 1
	Next
Loop
