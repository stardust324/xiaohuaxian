[Relative]
SetupOCXFile=
[Comment]
进入游戏开始页面即可，会一直进行游戏，请主动停止（F12）

[Attachment]



[UIPackage]



[Script]
Call Lib.附件.释放附件("D:\小花仙\七周年\表情包大作战\修修罗的跟踪日记")
'==========以下是按键精灵录制的内容==========
Rem begin
MoveTo 935, 783
Delay 1000
LeftClick 1
Delay 1
LeftUp 1
'==========以上是按键精灵录制的内容==========
//注意启动线程的参数是子程序名或函数名
//名字不带括号的, 如果你加了括号就变成调用函数子程序了
BeginThread 移动
Delay 100  //启动线程需要消耗资源, 所以记得加点延时
TracePrint "识别警戒状态" & Now()
Do
    //区域找图
	坐标 = Split(Plugin.TURING.FindImage(1240,466,1398,567,"D:\小花仙\七周年\表情包大作战\修修罗的跟踪日记\警戒.bmp",0.9), ",")
	x = CInt(坐标(0))
	y = Cint(坐标(1))
	If x > 0 And y > 0 Then 
    	KeyDown "space",1
    	TracePrint "戴面具"
    	Delay 2000
		KeyUp "space",1  
	End If
	//区域找图
	坐标 = Split(Plugin.TURING.FindImage(1025,794,1171,852,"D:\小花仙\七周年\表情包大作战\修修罗的跟踪日记\再来一次.bmp",0.9), ",")
	x = CInt(坐标(0))
	y = Cint(坐标(1))
	If x > 0 And y > 0 Then 	
		'==========以下是按键精灵录制的内容==========
		MoveTo 1102, 821
		Delay 1000
		LeftClick 1
		Delay 1
		LeftUp 1
		'==========以上是按键精灵录制的内容==========
		Goto begin
	End If 
Loop
Sub 移动()
	Delay 6000
	TracePrint "移动开始" & Now()
	KeyDown "Right", 1
	Delay 4500
	KeyUp "Right", 1
	TracePrint "移动结束" & Now()
End Sub
