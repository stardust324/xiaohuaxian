[General]
SyntaxVersion=2
BeginHotkey=116
BeginHotkeyMod=0
PauseHotkey=0
PauseHotkeyMod=0
StopHotkey=123
StopHotkeyMod=0
RunOnce=1
EnableWindow=
MacroID=33c305cc-4e7d-4b74-ac59-598314172e6d
Description=花神的阶梯_吹气球
Enable=1
AutoRun=0
[Repeat]
Type=0
Number=1
[SetupUI]
Type=1
QUI=Form1
[Relative]
SetupOCXFile=
[Comment]

[Attachment]



[UIPackage]



[Script]
Call Lib.附件.释放附件("D:\小花仙\七周年\花神的阶梯\吹气球")
'==========以下是按键精灵录制的内容==========
MoveTo 936, 816
Delay 1000
LeftClick 1
Delay 1
LeftUp 1
'==========以上是按键精灵录制的内容==========
Rem begin
//区域找其中图
坐标 = Split(Plugin.TURING.FindImageEx(461,262,1424,635,"D:\小花仙\七周年\花神的阶梯\吹气球\new.bmp|D:\小花仙\七周年\花神的阶梯\吹气球\again.bmp",0.7), ",")
id = CInt(坐标(0))
//TracePrint id
Select Case id
	Case 0
		LeftUp 1
    	Delay 2000
	Case 1
		LeftUp 1
    	MoveTo 1081, 746
    	Delay 1000
    	LeftClick 1
    	Delay 1
    	LeftUp 1
    	Delay 1000
End Select
Dim length, length1
length = 0
length1 = 1920
Delay 1000
Call Plugin.TURING.Incise_EraseData()
//获取屏幕图像数据
Call Plugin.TURING.Pixel_FromScreen(500, 271, 1444, 863)
//清除杂点
//Call Plugin.TURING.Filter_Despeckle(6)
//二值化处理
Call Plugin.TURING.Filter_Binaryzation("0000FF")
//显示获取的图像
//Call Plugin.TURING.Pixel_Preview()
//范围投影切割字符
num = Plugin.TURING.Incise_ScopeAisle(10, 10)
If num < 0 Then 
	TracePrint num + 1
	Goto begin
End If
//查看切割字符
//Plugin.TURING.Incise_Preview(0)
data = Split(Plugin.TURING.Incise_GetCharData(), "|")
length = Split(data(0), ",")(0)+11
//TracePrint "虚线左侧位置：" & length
LeftDown 1
Do
	Call Plugin.TURING.Incise_EraseData()
	Call Plugin.TURING.Pixel_FromScreen(500,540,950,840)
	//清除杂点
	//Call Plugin.TURING.Filter_Despeckle(6)
	Call Plugin.TURING.Filter_Binaryzation("9E8BE2")
	num2 = Plugin.TURING.Incise_ScopeAisle(10, 10)
	//TracePrint num2 + 1
	//获取切割字符数据内容
	data2 = Split(Plugin.TURING.Incise_GetCharData(), "|")
    l = Split(data2(0), ",")(0)
    If length1 - l >= 0 Then
    	length1 = l
    End If
	//TracePrint "气球左侧位置：" & length1
	If length - length1 >= 0 Then 
		LeftUp 1
		Delay 2000
		Goto begin
	End If
	//区域找其中图
	坐标 = Split(Plugin.TURING.FindImageEx(461,262,1424,635,"D:\小花仙\七周年\花神的阶梯\吹气球\new.bmp|D:\小花仙\七周年\花神的阶梯\吹气球\again.bmp",0.7), ",")
	id = CInt(坐标(0))
	//TracePrint id
	Select Case id
		Case 0
			LeftUp 1
    		Delay 2000
    		Goto begin
		Case 1
			LeftUp 1
    		MoveTo 1081, 746
    		Delay 1000
    		LeftClick 1
    		Delay 1
    		LeftUp 1
    		Delay 1000
    		Goto begin
	End Select
Loop