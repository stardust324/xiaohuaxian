[General]
SyntaxVersion=2
BeginHotkey=114
BeginHotkeyMod=0
PauseHotkey=0
PauseHotkeyMod=0
StopHotkey=123
StopHotkeyMod=0
RunOnce=1
EnableWindow=
MacroID=ab0e563c-f567-4bf3-88a3-14391c510000
Description=表情包大作战_微笑店员
Enable=1
AutoRun=0
[Repeat]
Type=0
Number=1
[SetupUI]
Type=1
QUI=Form1
[Relative]
SetupOCXFile=
[Comment]
打开微笑店员页面，在开始游戏界面即可，运行完自动停止

[Attachment]



[UIPackage]



[Script]
Call Lib.附件.释放附件("D:\小花仙\七周年\表情包大作战\微笑店员")

MoveTo 985, 767
Delay 1000
LeftClick 1
LeftUp 1
While True
	//区域找其中图
	坐标 = Split(Plugin.TURING.FindImage(864, 285, 937, 317, "D:\小花仙\七周年\表情包大作战\微笑店员\调配.bmp", 0.9), ",")
	x = CInt(坐标(0))
	y = Cint(坐标(1))
	Delay 500
	If x > 0 And y > 0 Then 
		//屏幕区域找多色
		坐标 = Split(Plugin.TURING.FindColorExS(399,468, 410,481, "11FEF5|46CAA6|DE8F56|0719E5|D558A2|FFFFFF", 0, 0.9), "|")
		For i = 0 To UBound(坐标)
    		xyS = Split(坐标(i), ",")    //输出每个颜色的坐标值
    		TracePrint xyS(0)
    		TracePrint xyS(1)
    		If Cint(xyS(0)) > 0 And CInt(xyS(1)) > 0 Then 
				choose (i)
    		End If
		Next
		Delay 1000
		//屏幕区域找多色
		坐标 = Split(Plugin.TURING.FindColorExS(444,468,454,481, "11FEF5|46CAA6|DE8F56|0719E5|D558A2|FFFFFF", 0, 0.9), "|")
		For i = 0 To UBound(坐标)
    		xyS = Split(坐标(i), ",")    //输出每个颜色的坐标值
    		TracePrint xyS(0)
    		TracePrint xyS(1)
    		If Cint(xyS(0)) > 0 And CInt(xyS(1)) > 0 Then 
				choose (i)
    		End If
		Next
	End If
	Delay 1000
	坐标 = Split(Plugin.TURING.FindImage(929,754,1046,821, "D:\小花仙\七周年\表情包大作战\微笑店员\结束.bmp", 0.9), ",")
	x = CInt(坐标(0))
	y = Cint(坐标(1))
	If x > 0 And y > 0 Then 
		MoveTo 988, 790
		Delay 1000
		LeftClick 1
		Delay 1
		LeftUp 1
		EndScript
	End If
Wend

Function choose(id)
	TracePrint id
	//<>---------------------------------------------以下是选择条件结结构判断
	Select Case id
	Case 0
    	MoveTo 1267,676
	Case 1
    	MoveTo 1422,673
	Case 2
    	MoveTo 1592,675
	Case 3
    	MoveTo 1273,858
	Case 4
    	MoveTo 1432,878
	Case 5
    	MoveTo 1586,867 
	End Select
	LeftClick 1
	Delay 1
	LeftUp 1
End Function
