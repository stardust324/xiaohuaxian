[Comment]
与小精灵交互，第一个按钮为陪它一起玩即可，当前只有陪它一起玩功能，运行完自动停止

[Attachment]



[UIPackage]



[Script]
Call Lib.附件.释放附件("D:\小花仙\七周年\双月花坊\水晶精灵")
//请先打开幽灵交互界面
//目前只有陪它一起玩功能
Delay 1000
MoveTo 1039, 505
LeftClick 1
Delay 1
LeftUp 1
//区域找其中图
Rem 识别
Delay 2000
坐标 = Split(Plugin.TURING.FindImageEx(351,404 ,438,496,"D:\小花仙\七周年\双月花坊\水晶精灵\拳头.bmp|D:\小花仙\七周年\双月花坊\水晶精灵\剪刀.bmp|D:\小花仙\七周年\双月花坊\水晶精灵\布.bmp",0.9), ",")
id = 坐标(0)
x = 坐标(1)
y = 坐标(2)
TracePrint id
Select Case id
    Case "0"
MoveTo 1186,688
    Case "1"
MoveTo 987,626
    Case "2"
MoveTo 790,689
    Case Else
	Goto 识别
End Select
LeftClick 1
Delay 1
LeftUp 1
//屏幕区域使用相似度查找图片
坐标 = Split(Plugin.TURING.FindImage(857,738, 1092,808, "D:\小花仙\七周年\双月花坊\水晶精灵\完成.bmp", 0.9),",")
intX = CInt(坐标(0))
intY = CInt(坐标(1))
If  intX> 0 And  intY> 0 Then 
	MoveTo 972, 776
	LeftClick 1
	Delay 1
	LeftUp 1
Else
	Goto 识别
End If